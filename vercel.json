{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd financial-dashboard/client && npm install && npm run build",
  "outputDirectory": "financial-dashboard/client/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}