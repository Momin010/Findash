{
  "name": "financial-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:api\"",
    "dev:client": "cd client && vite",
    "dev:api": "vercel dev --listen 3001",
    "build": "cd client && vite build",
    "deploy": "vercel --prod"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.10.3",
    "@supabase/supabase-js": "^2.100.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.0",
    "vercel": "^37.0.0"
  }
}